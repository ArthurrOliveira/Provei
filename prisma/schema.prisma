generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  reviews    Review[]
  following  Follow[]    @relation("Follower")
  followers  Follow[]    @relation("Following")
  mediaLikes MediaLike[]
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Restaurant {
  id            String   @id @default(uuid())
  name          String
  address       String
  googlePlaceId String?
  lat           Float?
  lng           Float?
  createdAt     DateTime @default(now())

  reviews Review[]
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  rating       Int?
  comment      String
  createdAt    DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  vibeTags   ReviewVibeTag[]
  media      ReviewMedia[]
}

model VibeTag {
  id    String @id @default(uuid())
  label String @unique

  reviews ReviewVibeTag[]
}

model ReviewVibeTag {
  reviewId  String
  vibeTagId String

  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  vibeTag VibeTag @relation(fields: [vibeTagId], references: [id], onDelete: Cascade)

  @@id([reviewId, vibeTagId])
}

enum MediaType {
  IMAGE
  VIDEO
}

model ReviewMedia {
  id           String    @id @default(uuid())
  reviewId     String
  url          String
  type         MediaType
  thumbnailUrl String?
  createdAt    DateTime  @default(now())

  review Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  likes  MediaLike[]
}

model MediaLike {
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  media ReviewMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([userId, mediaId])
}
