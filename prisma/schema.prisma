generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["tastecircle"]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  reviews      Review[]
  following    Follow[]            @relation("Follower")
  followers    Follow[]            @relation("Following")
  mediaLikes   MediaLike[]
  friendGroups FriendGroup[]
  groupMembers FriendGroupMember[]

  @@schema("tastecircle")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@schema("tastecircle")
}

model Restaurant {
  id            String   @id @default(uuid())
  name          String
  address       String
  googlePlaceId String?
  observacao    String?
  lat           Float?
  lng           Float?
  createdAt     DateTime @default(now())

  reviews Review[]

  @@schema("tastecircle")
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  rating       Int?
  comment      String
  createdAt    DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  vibeTags   ReviewVibeTag[]
  media      ReviewMedia[]

  @@schema("tastecircle")
}

model VibeTag {
  id    String @id @default(uuid())
  label String @unique

  reviews ReviewVibeTag[]

  @@schema("tastecircle")
}

model ReviewVibeTag {
  reviewId  String
  vibeTagId String

  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  vibeTag VibeTag @relation(fields: [vibeTagId], references: [id], onDelete: Cascade)

  @@id([reviewId, vibeTagId])
  @@schema("tastecircle")
}

enum MediaType {
  IMAGE
  VIDEO

  @@schema("tastecircle")
}

model ReviewMedia {
  id           String    @id @default(uuid())
  reviewId     String
  url          String
  type         MediaType
  thumbnailUrl String?
  createdAt    DateTime  @default(now())

  review Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  likes  MediaLike[]

  @@schema("tastecircle")
}

model MediaLike {
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  media ReviewMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([userId, mediaId])
  @@schema("tastecircle")
}

model FriendGroup {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  createdAt DateTime @default(now())

  owner   User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members FriendGroupMember[]

  @@schema("tastecircle")
}

model FriendGroupMember {
  groupId   String
  userId    String
  createdAt DateTime @default(now())

  group FriendGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@schema("tastecircle")
}
