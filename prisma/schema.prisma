generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["mangut"]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  reviews                  Review[]
  following                Follow[]            @relation("Follower")
  followers                Follow[]            @relation("Following")
  mediaLikes               MediaLike[]
  friendGroups             FriendGroup[]
  groupMembers             FriendGroupMember[]
  badges                   UserBadge[]
  restaurantLists          RestaurantList[]
  listLikes                ListLike[]
  receivedGroupInvitations GroupInvitation[]   @relation("ReceivedGroupInvitations")
  sentGroupInvitations     GroupInvitation[]   @relation("SentGroupInvitations")

  @@schema("mangut")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@schema("mangut")
}

model Restaurant {
  id                String   @id @default(uuid())
  name              String
  address           String
  googlePlaceId     String?  @unique
  observacao        String?
  lat               Float?
  lng               Float?
  phone             String?
  website           String?
  googleMapsUri     String?
  googleRating      Float?
  googleRatingCount Int?
  openingHours      Json?
  photoReferences   Json?
  createdAt         DateTime @default(now())

  reviews   Review[]
  listItems RestaurantListItem[]

  @@schema("mangut")
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  rating       Int?
  comment      String
  createdAt    DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  vibeTags   ReviewVibeTag[]
  media      ReviewMedia[]

  @@schema("mangut")
}

model VibeTag {
  id    String @id @default(uuid())
  label String @unique

  reviews ReviewVibeTag[]

  @@schema("mangut")
}

model ReviewVibeTag {
  reviewId  String
  vibeTagId String

  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  vibeTag VibeTag @relation(fields: [vibeTagId], references: [id], onDelete: Cascade)

  @@id([reviewId, vibeTagId])
  @@schema("mangut")
}

enum MediaType {
  IMAGE
  VIDEO

  @@schema("mangut")
}

model ReviewMedia {
  id           String    @id @default(uuid())
  reviewId     String
  url          String
  type         MediaType
  thumbnailUrl String?
  createdAt    DateTime  @default(now())

  review Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  likes  MediaLike[]

  @@schema("mangut")
}

model MediaLike {
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  media ReviewMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([userId, mediaId])
  @@schema("mangut")
}

model FriendGroup {
  id         String   @id @default(uuid())
  ownerId    String
  name       String
  inviteCode String?  @unique
  createdAt  DateTime @default(now())

  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     FriendGroupMember[]
  invitations GroupInvitation[]

  @@schema("mangut")
}

model FriendGroupMember {
  groupId   String
  userId    String
  createdAt DateTime @default(now())

  group FriendGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@schema("mangut")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED

  @@schema("mangut")
}

model GroupInvitation {
  id        String           @id @default(uuid())
  groupId   String
  invitedId String
  invitedBy String
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())

  group   FriendGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invited User        @relation("ReceivedGroupInvitations", fields: [invitedId], references: [id], onDelete: Cascade)
  sender  User        @relation("SentGroupInvitations", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@schema("mangut")
}

enum BadgeCategory {
  REVIEWER
  SOCIAL
  EXPLORER

  @@schema("mangut")
}

model Badge {
  id          String        @id @default(uuid())
  slug        String        @unique
  label       String
  description String
  iconUrl     String?
  category    BadgeCategory
  threshold   Json

  users UserBadge[]

  @@schema("mangut")
}

model UserBadge {
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@schema("mangut")
}

model RestaurantList {
  id            String   @id @default(uuid())
  userId        String
  title         String
  description   String?
  coverImageUrl String?
  isPublic      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items RestaurantListItem[]
  likes ListLike[]

  @@schema("mangut")
}

model RestaurantListItem {
  listId       String
  restaurantId String
  note         String?
  position     Int
  addedAt      DateTime @default(now())

  list       RestaurantList @relation(fields: [listId], references: [id], onDelete: Cascade)
  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@id([listId, restaurantId])
  @@schema("mangut")
}

model ListLike {
  userId    String
  listId    String
  createdAt DateTime @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  list RestaurantList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([userId, listId])
  @@schema("mangut")
}
